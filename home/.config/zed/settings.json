{
  "autosave": "on_focus_change",
  "cli_default_open_behavior": "new_window",
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "default_config_options": {
        "effort": "max",
        "mode": "acceptEdits",
        "model": "opus",
      },
      "type": "registry",
    },
  },
  "agent": {
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "model": "claude-opus-4-8",
      "provider": "zed.dev",
    },
    "dock": "left",
    "inline_assistant_model": {
      "model": "claude-sonnet-4-thinking",
      "provider": "zed.dev",
    },
  },
  "auto_install_extensions": {
    "csv": true,
    "git-firefly": true,
    "html": true,
    "nix": true,
    "nvim-nightfox": true,
    "toml": true,
    "xml": true,
  },
  "base_keymap": "VSCode",
  "buffer_font_size": 18,
  "edit_predictions": {
    "mode": "subtle",
  },
  "format_on_save": "on",
  "languages": {
    "Gleam": {
      "prettier": {
        "allowed": false,
      },
      "inlay_hints": {
        "enabled": true,
      },
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "YAML": {
      "formatter": "language_server",
    },
    "Rust": {
      "formatter": "language_server",
    },
  },
  "lsp": {
    "pyright": {
      "settings": {
        "python": {
          "analysis": {
            "diagnosticMode": "workspace",
            "typeCheckingMode": "strict",
          },
        },
      },
    },
  },
  "outline_panel": {
    "dock": "right",
  },
  "prettier": {
    "allowed": true,
    "plugins": [
      "prettier-plugin-organize-imports",
      "prettier-plugin-tailwindcss",
    ],
  },
  "project_panel": {
    "dock": "right",
    "indent_size": 10,
  },
  "relative_line_numbers": "enabled",
  "theme": "Carbonfox - opaque",
  "ui_font_size": 18,
  "vim_mode": true,
}
